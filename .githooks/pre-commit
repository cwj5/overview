#!/bin/bash

# Pre-commit hook to run tests before allowing commits
# This ensures code quality is maintained

set -e

echo "🧪 Running pre-commit checks..."
echo ""

# Colors for output
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get the git root directory
REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# Check if we're in the right directory
if [ ! -f "package.json" ]; then
    echo -e "${RED}❌ Error: package.json not found. Are you in the project root?${NC}"
    exit 1
fi

# Run TypeScript tests
echo -e "${YELLOW}Running TypeScript tests...${NC}"
TS_TEST_OUTPUT=$(npm test 2>&1)
TS_TEST_EXIT=$?

if [ $TS_TEST_EXIT -eq 0 ]; then
    echo -e "${GREEN}✓ TypeScript tests passed${NC}"
else
    echo -e "${RED}✗ TypeScript tests failed${NC}"
    echo "$TS_TEST_OUTPUT"
    exit 1
fi

echo ""

# Run Rust tests
echo -e "${YELLOW}Running Rust tests...${NC}"
# First run logger tests serially (to avoid global state conflicts)
LOGGER_TEST_LOG=$(mktemp)
if (cd "$REPO_ROOT/src-tauri" && cargo test --lib logger_tests -- --test-threads=1 >"$LOGGER_TEST_LOG" 2>&1); then
    echo -e "${GREEN}✓ Logger tests passed${NC}"
else
    echo -e "${RED}✗ Logger tests failed${NC}"
    cat "$LOGGER_TEST_LOG"
    rm -f "$LOGGER_TEST_LOG"
    exit 1
fi
rm -f "$LOGGER_TEST_LOG"

# Then run all other tests in parallel
OTHER_TEST_LOG=$(mktemp)
if (cd "$REPO_ROOT/src-tauri" && cargo test --lib -- --skip logger_tests >"$OTHER_TEST_LOG" 2>&1); then
    echo -e "${GREEN}✓ Other Rust tests passed${NC}"
else
    echo -e "${RED}✗ Other Rust tests failed${NC}"
    cat "$OTHER_TEST_LOG"
    rm -f "$OTHER_TEST_LOG"
    exit 1
fi
rm -f "$OTHER_TEST_LOG"

echo ""
echo -e "${GREEN}✅ All checks passed! Proceeding with commit.${NC}"
exit 0
